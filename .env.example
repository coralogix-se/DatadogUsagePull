# Datadog → Coralogix Usage Report — Configuration
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is read automatically when you run dd_usage_pull.py.
#
# Required permissions on the API key:  usage_read
# Required permissions on the App key:  usage_read, billing_read
#   (billing_read is optional — cost data will be skipped if missing)

# ── Authentication ────────────────────────────────────────────────────────
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_application_key_here

# ── Datadog site ──────────────────────────────────────────────────────────
# Options:
#   datadoghq.com        US (default)
#   datadoghq.eu         Europe
#   us3.datadoghq.com    US3
#   us5.datadoghq.com    US5
#   ddog-gov.com         US1-FED (GovCloud)
DD_SITE=datadoghq.com

# ── Reporting month ───────────────────────────────────────────────────────
# Format: YYYY-MM  (e.g. 2026-06)
# Leave blank to default to the previous calendar month.
DD_MONTH=
